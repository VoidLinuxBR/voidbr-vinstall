#!/bin/bash
# Generated by pkgmake
set -e

user="${SUDO_USER:-$USER}"
user_home=$(getent passwd "$user" | cut -d: -f6)

if [ -t 1 ]; then
	RESET="$(printf "%b" "\033[0m")"
	RST="$(printf "%b" "\033[0m")"
	BLACK="$(printf "%b" "\033[1;30m")"
	RED="$(printf "%b" "\033[1;31m")"
	GREEN="$(printf "%b" "\033[1;32m")"
	YELLOW="$(printf "%b" "\033[1;33m")"
	BLUE="$(printf "%b" "\033[1;34m")"
	MAGENTA="$(printf "%b" "\033[1;35m")"
	CYAN="$(printf "%b" "\033[1;36m")"
	WHITE="$(printf "%b" "\033[1;37m")"
fi
log() {
	printf "%s[*]%s %s - %s\n" "$CYAN" "${BLACK}$pkgname" "${RST}" "${CYAN}$*${RESET}" 1>&2
}
warn() {
	printf "%s[*]WARNING:%s %s - %s\n" "$YELLOW" "$RESET" "$pkgname" "$*" 1>&2
	exit 1
}
die() {
	printf "%s[*]FATAL:%s %s - %s\n" "$RED" "$RESET" "$pkgname" "$*" 1>&2
	exit 1
}
require_cmd() {
	command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

pre_install() {
	log "Iniciando instalação"
}

post_install() {
	log "Finalizando instalação"
}

pre_upgrade() {
	log "Iniciando upgrade"
}

post_upgrade() {
	log "Finalizando upgrade"
}

ACTION="$1"
action="$1"
PKGNAME="$2"
pkgname="$2"
VERSION="$3"
pkgver="$3"
UPDATE="$4"
update="$4"

case "$ACTION" in
pre)
	if [ "$UPDATE" = "yes" ]; then
		pre_upgrade
	else
		pre_install
	fi
	;;
post)
	if [ "$UPDATE" = "yes" ]; then
		post_upgrade
	else
		post_install
	fi
	;;
esac
